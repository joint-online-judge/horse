    "/api/v1/user/logout": {
      "get": {
        "tags": [
          "user"
        ],
        "summary": "Logout",
        "operationId": "logout_api_v1_user_logout_get",
        "parameters": [
          {
            "description": "Set the redirect url after the logout.",
            "required": false,
            "schema": {
              "title": "Redirect Url",
              "type": "string",
              "description": "Set the redirect url after the logout.",
              "default": "http://127.0.0.1:34765/"
            },
            "name": "redirect_url",
            "in": "query"
          },
          {
            "description": "If true (html link mode), redirect to a url; If false (ajax mode), return the redirect url, you also need to unset all cookies manually in ajax mode.",
            "required": false,
            "schema": {
              "title": "Redirect",
              "type": "boolean",
              "description": "If true (html link mode), redirect to a url; If false (ajax mode), return the redirect url, you also need to unset all cookies manually in ajax mode.",
