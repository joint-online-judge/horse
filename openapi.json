        "tags": [
          "user"
        ],
        "summary": "Jaccount Login",
        "operationId": "jaccount_login_api_v1_user_jaccount_login_get",
        "parameters": [
          {
            "description": "Set the redirect url after the authorization.",
            "required": false,
            "schema": {
              "title": "Redirect Url",
              "type": "string",
              "description": "Set the redirect url after the authorization.",
              "default": "http://127.0.0.1:34765/"
            },
            "name": "redirect_url",
            "in": "query"
          },
          {
            "description": "If true (html link mode), redirect to jaccount site; If false (ajax mode), return the redirect url to the jaccount site, you also need to set the cookies returned manually in ajax mode.",
            "required": false,
            "schema": {
              "title": "Redirect",
              "type": "boolean",
              "description": "If true (html link mode), redirect to jaccount site; If false (ajax mode), return the redirect url to the jaccount site, you also need to set the cookies returned manually in ajax mode.",
              "default": true
            },
            "name": "redirect",
            "in": "query"
